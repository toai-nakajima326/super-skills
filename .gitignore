node_modules/
.DS_Store
*.log
.env
.install-state.json

# Generated outputs (rebuild with `npm run build`)
.claude/skills/
.agents/skills/
.codex/
.cursor/rules/skills/
.kiro/skills/
.antigravity/skills/

# Runtime database files (live server modifies these continuously)
data/*.sqlite
data/*.sqlite-journal
data/*.sqlite-shm
data/*.sqlite-wal
data/*.db
data/*.db-shm
data/*.db-wal

# Append-only entries log (contains raw user data — never commit)
data/entries-wal.jsonl
data/entries-wal.jsonl.*

# Daily morning briefs (local notifications)
data/morning-briefs/

# Python cache
scripts/__pycache__/

# Large model files
models/*.data
.claude/worktrees/
.claude/worktrees/
data/snapshots/
data/experiments/

# Atomic-write backup staging + rotated previous (multi-GB, never commit)
data/vcontext-backup.sqlite
data/vcontext-backup.sqlite.tmp
data/vcontext-backup.sqlite.tmp-journal
data/vcontext-backup.sqlite.bak
data/vcontext-backup.sqlite-wal
data/vcontext-backup.sqlite-shm
# WAL companions that appear when something opens the .bak in WAL mode
# (e.g. quick_check) — always transient, not source.
data/vcontext-backup.sqlite.bak-wal
data/vcontext-backup.sqlite.bak-shm
# Recovered corrupt RAM DB snapshots (post-incident forensics, multi-GB)
data/vcontext-ram-corrupt-*.db
